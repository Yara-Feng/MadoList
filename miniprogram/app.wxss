/**
 * MadoList 全局样式
 */

/* CSS 变量 */
page {
  --color-primary: #0052D9;
  --color-primary-light: #E8F0FE;
  --color-success: #2BA471;
  --color-warning: #E37318;
  --color-danger: #D54941;
  --color-info: #909399;

  --color-bg: #F5F5F5;
  --color-bg-white: #FFFFFF;
  --color-text-primary: #1D1D1D;
  --color-text-secondary: #717171;
  --color-text-placeholder: #BBBBBB;
  --color-border: #E7E7E7;
  --color-divider: #F0F0F0;

  --font-size-xs: 20rpx;
  --font-size-sm: 24rpx;
  --font-size-base: 28rpx;
  --font-size-lg: 32rpx;
  --font-size-xl: 36rpx;
  --font-size-xxl: 40rpx;

  --spacing-xs: 8rpx;
  --spacing-sm: 16rpx;
  --spacing-md: 24rpx;
  --spacing-lg: 32rpx;
  --spacing-xl: 48rpx;

  --radius-sm: 8rpx;
  --radius-md: 16rpx;
  --radius-lg: 24rpx;
  --radius-round: 50%;

  --shadow-sm: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
  --shadow-md: 0 4rpx 16rpx rgba(0, 0, 0, 0.1);

  --page-padding: 32rpx;

  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
  font-size: var(--font-size-base);
  color: var(--color-text-primary);
  background-color: var(--color-bg);
  box-sizing: border-box;
}

button {
  background: initial;
}

button:focus {
  outline: 0;
}

button::after {
  border: none;
}

/* 通用布局 */
.container {
  padding: var(--page-padding);
  min-height: 100vh;
  box-sizing: border-box;
}

.flex-row {
  display: flex;
  flex-direction: row;
  align-items: center;
}

.flex-column {
  display: flex;
  flex-direction: column;
}

.flex-between {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.flex-1 {
  flex: 1;
}

.text-center {
  text-align: center;
}

.text-right {
  text-align: right;
}

/* 间距 */
.mt-xs { margin-top: var(--spacing-xs); }
.mt-sm { margin-top: var(--spacing-sm); }
.mt-md { margin-top: var(--spacing-md); }
.mt-lg { margin-top: var(--spacing-lg); }
.mb-sm { margin-bottom: var(--spacing-sm); }
.mb-md { margin-bottom: var(--spacing-md); }
.mb-lg { margin-bottom: var(--spacing-lg); }
.ml-sm { margin-left: var(--spacing-sm); }
.mr-sm { margin-right: var(--spacing-sm); }

/* 卡片 */
.card {
  background: var(--color-bg-white);
  border-radius: var(--radius-md);
  padding: var(--spacing-md);
  margin-bottom: var(--spacing-md);
  box-shadow: var(--shadow-sm);
}

/* 按钮 */
.btn {
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: var(--radius-md);
  font-size: var(--font-size-base);
  padding: 20rpx 40rpx;
  border: none;
  outline: none;
}

.btn-primary {
  background: var(--color-primary);
  color: #FFFFFF;
}

.btn-outline {
  background: transparent;
  color: var(--color-primary);
  border: 2rpx solid var(--color-primary);
}

.btn-danger {
  background: var(--color-danger);
  color: #FFFFFF;
}

.btn-sm {
  padding: 12rpx 24rpx;
  font-size: var(--font-size-sm);
}

.btn-block {
  width: 100%;
}

/* 文字 */
.text-sm { font-size: var(--font-size-sm); }
.text-base { font-size: var(--font-size-base); }
.text-lg { font-size: var(--font-size-lg); }
.text-xl { font-size: var(--font-size-xl); }

.text-secondary { color: var(--color-text-secondary); }
.text-placeholder { color: var(--color-text-placeholder); }
.text-primary { color: var(--color-primary); }
.text-danger { color: var(--color-danger); }
.text-success { color: var(--color-success); }
.text-warning { color: var(--color-warning); }

.text-bold { font-weight: 600; }

.text-ellipsis {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 标签 */
.tag {
  display: inline-flex;
  align-items: center;
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
  font-size: var(--font-size-xs);
}

.tag-priority-high {
  background: #FDECEC;
  color: #D54941;
}

.tag-priority-medium {
  background: #FFF3E8;
  color: #E37318;
}

.tag-priority-low {
  background: #E8F0FE;
  color: #0052D9;
}

.tag-visibility-personal {
  background: #F3F3F3;
  color: #717171;
}

.tag-visibility-group {
  background: #E8F8EE;
  color: #2BA471;
}

.tag-status-todo {
  background: #E8F0FE;
  color: #0052D9;
}

.tag-status-done {
  background: #E8F8EE;
  color: #2BA471;
}

/* 分隔线 */
.divider {
  height: 1rpx;
  background: var(--color-divider);
  margin: var(--spacing-md) 0;
}

/* 头像 */
.avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: var(--radius-round);
  overflow: hidden;
  background: var(--color-bg);
}

.avatar-sm {
  width: 60rpx;
  height: 60rpx;
}

.avatar-lg {
  width: 120rpx;
  height: 120rpx;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
}

.empty-state image {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: var(--spacing-md);
}

.empty-state text {
  color: var(--color-text-placeholder);
  font-size: var(--font-size-base);
}

/* 红点 */
.badge {
  position: relative;
}

.badge::after {
  content: '';
  position: absolute;
  top: -4rpx;
  right: -4rpx;
  width: 16rpx;
  height: 16rpx;
  background: var(--color-danger);
  border-radius: var(--radius-round);
  border: 2rpx solid #fff;
}
