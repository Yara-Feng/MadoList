/* pages/profile/profile.wxss */

.user-profile-card {
  padding: var(--spacing-lg);
}

.avatar-btn {
  background: transparent;
  border: none;
  padding: 0;
  margin: 0 auto;
  display: block;
  line-height: 1;
}

.avatar-btn::after {
  border: none;
}

.nickname-input {
  border: 2rpx solid var(--color-primary);
  border-radius: var(--radius-sm);
  padding: 8rpx 16rpx;
  font-size: var(--font-size-base);
  width: 300rpx;
  text-align: center;
}

.setting-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: var(--spacing-sm) 0;
}
