<!-- pages/calendar/calendar.wxml -->
<view class="container">
  <!-- 视图切换 -->
  <view class="view-switcher">
    <view
      wx:for="{{viewOptions}}" wx:key="value"
      class="switch-item {{currentView === item.value ? 'switch-item-active' : ''}}"
      data-value="{{item.value}}"
      bindtap="onSwitchView"
    >{{item.label}}</view>
  </view>

  <!-- 模式切换 -->
  <view class="mode-switcher">
    <view
      wx:for="{{modeOptions}}" wx:key="value"
      class="switch-item {{currentMode === item.value ? 'switch-item-active' : ''}}"
      data-value="{{item.value}}"
      bindtap="onSwitchMode"
    >{{item.label}}</view>
  </view>

  <!-- 月视图 -->
  <view wx:if="{{currentView === 'month'}}" class="month-view">
    <!-- 月份导航 -->
    <view class="month-nav">
      <text class="nav-arrow" bindtap="onPrevMonth">◀</text>
      <text class="month-title">{{currentYear}}年{{currentMonth}}月</text>
      <text class="nav-arrow" bindtap="onNextMonth">▶</text>
    </view>

    <!-- 星期标题 -->
    <view class="weekday-header">
      <text wx:for="{{['日','一','二','三','四','五','六']}}" wx:key="*this" class="weekday-item">{{item}}</text>
    </view>

    <!-- 日期网格 -->
    <view class="date-grid">
      <view
        wx:for="{{getCalendarGrid()}}" wx:key="index"
        class="date-cell {{item.empty ? 'date-empty' : ''}} {{item.isToday ? 'date-today' : ''}}"
        data-date="{{item.date}}"
        bindtap="onSelectDate"
      >
        <text wx:if="{{!item.empty}}" class="date-num">{{item.day}}</text>
        <view wx:if="{{item.hasTask}}" class="date-dot"></view>
      </view>
    </view>
  </view>

  <!-- 日期待办详情弹层 -->
  <view class="day-tasks-panel" wx:if="{{showDayTasks}}">
    <view class="day-tasks-header">
      <text class="text-lg text-bold">{{selectedDate}}</text>
      <text class="text-primary" bindtap="closeDayTasks">关闭</text>
    </view>
    <view wx:if="{{dayTasks.length === 0}}" class="empty-state">
      <text>该日期暂无待办</text>
    </view>
    <view wx:for="{{dayTasks}}" wx:key="_id" class="card day-task-card" bindtap="goToDetail" data-id="{{item._id}}">
      <view class="flex-row">
        <view class="flex-1">
          <text class="text-base {{item.status === 'DONE' ? 'task-title-done' : ''}}">{{item.title}}</text>
          <view class="flex-row mt-xs">
            <view class="tag {{item.priority === 'HIGH' ? 'tag-priority-high' : item.priority === 'MEDIUM' ? 'tag-priority-medium' : 'tag-priority-low'}}">
              {{item.priority === 'HIGH' ? '高' : item.priority === 'MEDIUM' ? '中' : '低'}}
            </view>
            <text class="text-sm text-secondary ml-sm">{{item.status === 'DONE' ? '✅已完成' : '⭕未完成'}}</text>
          </view>
        </view>
        <text class="text-secondary">→</text>
      </view>
    </view>
  </view>
</view>
