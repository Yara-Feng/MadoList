/* pages/group/join.wxss */

.code-input {
  width: 80%;
  margin: 0 auto;
  display: block;
  padding: 20rpx 16rpx;
  border: 2rpx solid var(--color-border);
  border-radius: var(--radius-sm);
  font-size: 48rpx;
  font-weight: 700;
  text-align: center;
  letter-spacing: 12rpx;
  box-sizing: border-box;
}

.code-input:focus {
  border-color: var(--color-primary);
}
