/* pages/tasks/tasks.wxss */

.toolbar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: var(--spacing-sm) var(--spacing-md);
  background: var(--color-bg-white);
  border-bottom: 1rpx solid var(--color-border);
  position: sticky;
  top: 0;
  z-index: 10;
}

.toolbar-left {
  display: flex;
  gap: var(--spacing-md);
}

.toolbar-btn {
  display: flex;
  align-items: center;
  padding: 8rpx 16rpx;
  border-radius: var(--radius-sm);
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
}

.toolbar-btn.active {
  background: var(--color-primary-light);
  color: var(--color-primary);
}

.arrow {
  font-size: 16rpx;
  margin-left: 4rpx;
}

.panel {
  background: var(--color-bg-white);
  padding: var(--spacing-md);
  border-bottom: 1rpx solid var(--color-border);
}

.panel-section {
  margin-bottom: var(--spacing-sm);
}

.panel-section:last-child {
  margin-bottom: 0;
}

.panel-label {
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
  margin-bottom: var(--spacing-xs);
  display: block;
}

.panel-tags {
  display: flex;
  flex-wrap: wrap;
  gap: var(--spacing-xs);
}

.panel-tag {
  padding: 8rpx 20rpx;
  background: var(--color-bg);
  border-radius: 32rpx;
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
}

.panel-tag-active {
  background: var(--color-primary-light);
  color: var(--color-primary);
}

.task-list {
  padding: var(--spacing-sm) 0;
}

.task-card {
  margin: 0 var(--spacing-md) var(--spacing-sm);
  padding: var(--spacing-sm) var(--spacing-md);
}

.task-done {
  opacity: 0.7;
}

.task-title-done {
  text-decoration: line-through;
  color: var(--color-text-placeholder);
}

.checkbox {
  font-size: 40rpx;
  line-height: 1;
  flex-shrink: 0;
}

.fab {
  position: fixed;
  right: 40rpx;
  bottom: 120rpx;
  width: 96rpx;
  height: 96rpx;
  background: var(--color-primary);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(0, 82, 217, 0.3);
  z-index: 100;
}

.fab-icon {
  color: #fff;
  font-size: 48rpx;
  font-weight: 300;
}
